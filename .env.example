# Copy to .env and fill values
# For Gmail: Enable 2FA, create App Password at https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

TZENIX_EMAIL=tzenix86@gmail.com
TZENIX_PHONE=+923232186947
TZENIX_COMPANY=TZENIX

# Comma-separated frontend origins allowed to call the API
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000

# Validation and payload hardening
MAX_MESSAGE_LENGTH=3000
MAX_NAME_LENGTH=80
MAX_COMPANY_LENGTH=120
